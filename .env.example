# ──────────────────────────────────────────────────────────────
# MEAT GUARD — Firebase configuration (OPTIONAL overrides)
# ──────────────────────────────────────────────────────────────
# ค่า config ของโปรเจกต์หลัก (meat-83f83) ฝังอยู่ในโค้ดแล้วที่
# src/lib/firebase.ts — โดยปกติ "ไม่ต้องสร้างไฟล์ .env เลย"
#
# ใช้ไฟล์นี้เฉพาะเมื่อต้องการชี้แอปไปยังโปรเจกต์ Firebase อื่น:
#   1. คัดลอกไฟล์นี้เป็น ".env" แล้วกรอกค่าจาก Firebase Console
#   2. ค่าใน .env จะ override ค่า default ที่ฝังไว้
# ──────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Realtime Database URL, e.g. https://<project>-default-rtdb.<region>.firebasedatabase.app
VITE_FIREBASE_DATABASE_URL=
