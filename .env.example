# ──────────────────────────────────────────────────────────────
# MEAT GUARD — Firebase configuration
# ──────────────────────────────────────────────────────────────
# 1. Create a project at https://console.firebase.google.com
# 2. Add a Web App, then copy the config values below.
# 3. Enable: Authentication > Sign-in method > Google
# 4. Enable: Realtime Database (and paste the rules from FIREBASE_RULES.json)
# 5. Copy this file to ".env" and fill in the values.
#
# NOTE: If these are left blank, MEAT GUARD automatically runs in
#       DEMO MODE — Google login is simulated and sensor values are
#       generated locally so you can explore the full UI offline.
# ──────────────────────────────────────────────────────────────

VITE_FIREBASE_API_KEY=
VITE_FIREBASE_AUTH_DOMAIN=
VITE_FIREBASE_PROJECT_ID=
VITE_FIREBASE_STORAGE_BUCKET=
VITE_FIREBASE_MESSAGING_SENDER_ID=
VITE_FIREBASE_APP_ID=

# Realtime Database URL, e.g. https://meat-guard-xxxx-default-rtdb.firebaseio.com
VITE_FIREBASE_DATABASE_URL=
